version="$Id: transversal.lib  2022-17-03 $";
category="Singularities";
info="
LIBRARY: transversal.lib    Complete transversals

AUTHORS: C. Munoz-Cabello,  chmuca@alumni.uv.es

PROCEDURES:
   classify(f, G, [k, j]);  classification of f under G-equivalence using the
                            method of complete transversals
";

//LIB "general.lib";      // product
//LIB "presmatrix.lib";   // presmatrix
//LIB "ring.lib";         // ord_test
//LIB "sing.lib";         // milnor

//-----------------------------------------------------------------------------
proc invariants(map f)
"USAGE:   invariants(f);  f = map
COMPUTE:  invariants of a corank 1 frontal surface, using the formulas from
          C. Munoz-Cabello, J.J. Nuno-Ballesteros and R. Oset-Sinha's "\"\
RETURN:   * number of swallowtails (@S), cusp-folds (@K), triple points (@T)
            and folded Whitney umbrellas (@W) in the disentanglement of f
          * cuspidal edge (@cuspedge) and double point (@dpoints) curves,
            along with their Milnor numbers
          * frontal Milnor number
REMARK:   This version of invariants is only beta. Please send bugs and
          comments to: <https://github.com/Nelynx/Seminario-SINGULAR>
          Known to work on Singular version 4.2.0.
NOTE:     objects with @ sign are exported to global scope
EXAMPLE:  example invariants; shows an example"
{
 
}
example
{
 "EXAMPLE";
 echo = 2;

 
}

//-----------------------------------------------------------------------------
proc classify(map f, list #)
"USAGE:   classify(f, [G, k, j]);  f = map, G = string, k,j = int
COMPUTE:
RETURN:
REMARK:
NOTE:
EXAMPLE:"
{
  /* optional parameters are declared as `list #`
   * (list is a polymorphism; see
   * https://www.singular.uni-kl.de/Manual/4-0-3/sing_44.htm)
   *
   * #[1]: group
   * #[2]: degree of the jet-space
   * #[3]: fix terms up to this degree */

  eh_classify(f, #);  // exception handling

  /* if `f` is a jet in `J^k(n,p)` and `j < k`, `TG_jf = m^{j+1} L_Gf`
   *
   * the definition of `Lf` depends on `G`, but the complete transversals
   * method works the same for `G = A, C, K, L, R` */
     
  if (G == 'C')
  {
    int p = size(preimage(f));
    module L = f * freemodule(p);
  }
  if (G == 'L')
    {}
  if (G == 'R')
    { module L = jacob(f); }

  if (G == 'A')
  {
  }
  
  if (G == 'K')
  {
    int p = size(preimage(f));
    module L = jacob(f) + f * freemodule(p);
  }  
}

//-----------------------------------------------------------------------------
static proc excep_handle_classify(f, #)
{
   if (size(#) == 0)
   {
      if (size(preimage(f)) == 1) { string G = "R"; }
  	  else { string G = "A"; }
  }
  else
  {
     if (size(#[1]) > 1)
       { ERROR("first argument must be a single letter!"); }
    
  	 if (#[2] < max(mapdeg(f)))
  	   { ERROR("degree of " + nameof(f) + " higher than " + #[1]); }
  }
}

//-----------------------------------------------------------------------------
static proc determined(ideal i, int k)
{
  /* use Nakayama's lemma
   * - save cpu cycles
   * - stop condition if upper bound for the degree is omitted */
}

//-----------------------------------------------------------------------------
static proc mapdeg(map f)
{
  /* turn the `deg` procedure into a map (see
   * https://en.wikipedia.org/wiki/Map_(higher-order_function)
   * for details) */

  intvec degf;
   
  for (int i = 1; i <= size(preimage(f)); i++) { degf[i] = deg(f[i]); }

  return degf;
}

