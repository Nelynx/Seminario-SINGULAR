//-----------------------------------------------------------------------------
static proc TC(map f, list #)
{
  // C-tangent jet-space

   int upperbound = #[1];  // upper bound for the degree of the jet-space
   int fixdeg = #[2];      // fix terms of degree <= `fixdeg`
}

//-----------------------------------------------------------------------------
static proc TL(map f, int upperbound, int fixdeg)
{
  // L-tangent jet-space

  int upperbound = #[1];  // upper bound for the degree of the jet-space
  int fixdeg = #[2];      // fix terms of degree <= `fixdeg`

}

//-----------------------------------------------------------------------------
static proc TR(map f, int upperbound, int fixdeg)
{
  // R-tangent jet-space
 	
